<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom layer: dark surface with rounded corners -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/colorSurface" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Top layer: vertical gradient overlay for text readability -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@color/colorTransparent"
                android:endColor="@color/colorOverlayDark"
                android:type="linear" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
