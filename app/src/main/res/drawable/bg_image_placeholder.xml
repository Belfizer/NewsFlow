<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base rectangle -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/colorSurface" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <!-- Diagonal stripe pattern using rotate -->
    <item>
        <rotate
            android:fromDegrees="45"
            android:pivotX="50%"
            android:pivotY="50%">
            <shape android:shape="rectangle">
                <gradient
                    android:angle="0"
                    android:startColor="@color/colorStripePattern"
                    android:centerColor="@color/colorSurface"
                    android:endColor="@color/colorStripePattern"
                    android:type="linear" />
            </shape>
        </rotate>
    </item>
</layer-list>
