<?xml version="1.0" encoding="utf-8"?>
<!--
    HomeFragment layout — owns the full CoordinatorLayout with collapsing header,
    search bar, breaking news carousel, category grid, and news RecyclerView.
    All sections previously in activity_main.xml (Assignment 2) are here.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".fragments.HomeFragment">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:background="@color/colorBackground"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:contentScrim="@color/colorBackground"
            app:statusBarScrim="@color/colorBackground"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:titleEnabled="false">

            <!-- Parallax header -->
            <FrameLayout
                android:id="@+id/headerFrame"
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:background="@drawable/bg_header_gradient"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="32dp"
                android:paddingBottom="16dp"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.5">

                <!-- Greeting block (bottom-start) -->
                <LinearLayout
                    android:id="@+id/greetingBlock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:layout_marginEnd="64dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="Good Morning, Ahmed 📰" />

                    <TextView
                        android:id="@+id/tvGreetingSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif"
                        android:text="@string/greeting_subtitle"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Notification bell with badge (top-end, L5) -->
                <FrameLayout
                    android:id="@+id/notificationContainer"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="12dp">

                    <ImageView
                        android:id="@+id/ivNotificationBell"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/content_desc_notification"
                        android:src="@drawable/ic_notification"
                        android:tint="@color/colorTextPrimary" />

                    <TextView
                        android:id="@+id/tvNotificationBadge"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="2dp"
                        android:layout_marginEnd="2dp"
                        android:background="@drawable/bg_badge"
                        android:gravity="center"
                        android:text="@string/notification_badge_count"
                        android:textColor="@color/colorWhite"
                        android:textSize="9sp"
                        android:textStyle="bold" />
                </FrameLayout>

            </FrameLayout>

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@color/colorTransparent"
                app:layout_collapseMode="pin"
                app:title=""
                app:titleTextColor="@color/colorTextPrimary" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable content body -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorBackground"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- Search bar -->
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_search_bar"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="8dp"
                android:drawableTint="@color/colorTextMuted"
                android:fontFamily="sans-serif"
                android:hint="Search articles..."
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/colorTextPrimary"
                android:textColorHint="@color/colorTextMuted"
                android:textSize="14sp" />

            <!-- SECTION A: Breaking News Carousel (L8) -->
            <LinearLayout
                android:id="@+id/breakingSectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="12dp">

                <TextView
                    android:id="@+id/tvBreakingLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_breaking_banner"
                    android:fontFamily="sans-serif"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="@string/section_breaking"
                    android:textAllCaps="true"
                    android:textColor="@color/colorWhite"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="8dp"
                    android:layout_height="0dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:text="Top stories right now"
                    android:textColor="@color/colorTextMuted"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- L8: HorizontalScrollView for featured cards -->
            <HorizontalScrollView
                android:id="@+id/breakingCarouselScrollView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:scrollbars="none">

                <!-- Featured cards injected here by FeaturedAdapter -->
                <LinearLayout
                    android:id="@+id/breakingCarouselContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />

            </HorizontalScrollView>

            <!-- SECTION B: Category Grid (L6) -->
            <RelativeLayout
                android:id="@+id/categorySectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="28dp"
                android:paddingBottom="12dp">

                <TextView
                    android:id="@+id/tvCategoryHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="sans-serif"
                    android:text="@string/section_browse_category"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCategorySeeAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:minHeight="48dp"
                    android:text="@string/section_see_all"
                    android:textColor="@color/colorPrimary"
                    android:textSize="13sp" />
            </RelativeLayout>

            <!-- L6: GridLayout — categories injected by CategoryAdapter -->
            <GridLayout
                android:id="@+id/categoryGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:rowCount="3"
                android:useDefaultMargins="true" />

            <!-- SECTION C: Latest Headlines -->
            <TextView
                android:id="@+id/tvLatestHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="28dp"
                android:paddingBottom="12dp"
                android:text="@string/section_latest_headlines"
                android:textColor="@color/colorTextPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_divider" />

            <!-- News RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLatestNews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingTop="8dp"
                tools:itemCount="5"
                tools:listitem="@layout/item_news_card" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
